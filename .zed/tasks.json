[
  {
    "label": "Init",
    "command": "rbenv install -s && bundle config set --local default_install_uses_path true && bundle config set --local disable_shared_gems true && bundle config set --local with development && bundle install"
  },
  {
    "label": "Build",
    "command": "rake build"
  },
  {
    "label": "Run",
    "command": "rake serve"
  },
  {
    "label": "Clean",
    "command": "rake clean"
  },
  {
    "label": "Check",
    "command": "rake check"
  },
  {
    "label": "Create Draft",
    "command": "rake create_draft"
  },
  {
    "label": "Create Page",
    "command": "rake create_page"
  },
  {
    "label": "Create Post",
    "command": "rake create_post"
  },
  {
    "label": "Publish",
    "command": "rake publish"
  }
]
